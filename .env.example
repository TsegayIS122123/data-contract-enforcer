# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxx

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith Configuration
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=data-contract-enforcer
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Git Configuration
GIT_REPO_PATH=/path/to/your/week1-5/repos
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=your.email@example.com

# Contract Configuration
CONTRACT_DEFAULT_OWNER=data-engineering-team
CONTRACT_DEFAULT_VERSION=1.0.0
STATISTICAL_DRIFT_WARNING_ZSCORE=2.0
STATISTICAL_DRIFT_FAILURE_ZSCORE=3.0
EMBEDDING_DRIFT_THRESHOLD=0.15
LLM_VIOLATION_WARNING_RATE=0.02

# Report Configuration
REPORT_OUTPUT_DIR=enforcer_report
REPORT_HTML_TEMPLATE=config/report_template.html
REPORT_INCLUDE_VIOLATIONS=true
REPORT_INCLUDE_SCHEMA_CHANGES=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/enforcer.log
